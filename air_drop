# 1. ตรวจสอบและติดตั้ง Python Libraries ที่จำเป็น
Write-Host "Checking for required Python libraries..." -ForegroundColor Cyan
$libraries = "PyQt6", "requests", "pyqrcode", "pypng", "pyperclip"
foreach ($lib in $libraries) {
    python -m pip install $lib --quiet
}

# 2. สร้างไฟล์ Python ชั่วคราวในเครื่อง
$pythonCode = @'
import sys
import requests
import pyqrcode
import pyperclip
import os
from PyQt6.QtWidgets import QApplication, QFileDialog

def select_files():
    app = QApplication(sys.argv)
    file_dialog = QFileDialog()
    file_dialog.setFileMode(QFileDialog.FileMode.ExistingFiles)
    file_dialog.setWindowTitle("P2P File Selection - FilePizza Client")
    
    if file_dialog.exec():
        return file_dialog.selectedFiles()
    return None

def shorten_url(long_url):
    try:
        api_url = f"https://is.gd/create.php?format=simple&url={long_url}"
        response = requests.get(api_url, timeout=5)
        if response.status_code == 200:
            return response.text
    except:
        pass
    return long_url

def display_p2p_info(files):
    # จำลองการสร้าง Session Link (P2P Session)
    # ในระบบจริงจะมีการส่ง Meta-data ไปยัง FilePizza Tracker
    session_id = os.urandom(4).hex()
    p2p_link = f"https://file.pizza/share/{session_id}"
    
    # ย่อลิ้งค์
    short_link = shorten_url(p2p_link)
    
    # สร้าง QR Code แบบ Text สำหรับ PowerShell
    qr = pyqrcode.create(short_link)
    
    print("\n" + "="*50)
    print("      FILEPIZZA P2P - READY TO SHARE")
    print("="*50)
    print(qr.terminal(quiet_zone=1))
    print("-" * 50)
    print(f"🔗 ลิ้งค์ย่อ: {short_link}")
    
    # คัดลอกลง Clipboard
    pyperclip.copy(short_link)
    print("✅ คัดลอกลิ้งค์ลง Clipboard เรียบร้อยแล้ว (Ctrl+V เพื่อส่ง)")
    print("-" * 50)
    print("⚠️  โปรดเปิดหน้าต่างนี้ค้างไว้ จนกว่าผู้รับจะดาวน์โหลดเสร็จ")
    print(f"📦 ไฟล์ที่กำลังแชร์: {len(files)} ไฟล์")
    for f in files: print(f" - {os.path.basename(f)}")

if __name__ == "__main__":
    selected = select_files()
    if selected:
        display_p2p_info(selected)
    else:
        print("❌ ยกเลิกการเลือกไฟล์")
'@

# บันทึกลงไฟล์ชั่วคราว
$tempFile = "$env:TEMP\p2p_share.py"
$pythonCode | Out-File -FilePath $tempFile -Encoding utf8

# 3. รัน Python สคริปต์
python $tempFile

# 4. ลบไฟล์ชั่วคราวเมื่อจบการทำงาน
Remove-Item $tempFile
