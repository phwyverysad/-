Add-Type -AssemblyName System.Windows.Forms
$FileBrowser = New-Object System.Windows.Forms.OpenFileDialog -Property @{ 
    InitialDirectory = [Environment]::GetFolderPath('Desktop') 
    Filter = "All Files (*.*)|*.*"
    Title = "เลือกไฟล์เพื่อตรวจสอบชื่อไวรัสแบบตาราง"
}

$null = $FileBrowser.ShowDialog()
$filePath = $FileBrowser.FileName

if (-not $filePath) { Write-Host "[-] ไม่ได้เลือกไฟล์" -ForegroundColor Yellow; exit }

# ใส่ API Key ของคุณที่นี่
$apiKey = "2a359ba5f1ce8ff799adabc8903416c1b6bc9c4bc35a88dfae1e24c2061fd7fd"

$blacklist = @("Xworm", "Backdoor", "Dropper", "AsyncRAT", "Njrat", "Stealer", "Spy", "Pyinstaller", "Python", "Expiro", "Rat")

Write-Host "`n[*] กำลังคำนวณ Hash และดึงข้อมูลจาก VirusTotal..." -ForegroundColor Cyan
$fileHash = (Get-FileHash -Path $filePath -Algorithm SHA256).Hash
$headers = @{ "x-apikey" = $apiKey }

try {
    $response = Invoke-RestMethod -Uri "https://www.virustotal.com/api/v3/files/$fileHash" -Headers $headers -Method Get
    $allResults = $response.data.attributes.last_analysis_results.Values | Where-Object { $_.result -ne $null }
    
    # --- แยกตารางคำต้องห้าม ---
    $foundInBlacklist = @()
    foreach ($item in $allResults) {
        foreach ($word in $blacklist) {
            if ($item.result -ilike "*$word*") {
                $foundInBlacklist += [PSCustomObject]@{
                    'MATCHED KEYWORD' = $word.ToUpper()
                    'VIRUS NAME'      = $item.result
                    'ANTIVIRUS ENGINE' = $item.engine_name
                }
                break
            }
        }
    }

    # --- เริ่มการแสดงผลตาราง ---
    Write-Host "`n" + ("=" * 85) -ForegroundColor White
    Write-Host " รายงานผลตรวจสอบ: $($response.data.attributes.meaningful_name)" -ForegroundColor Cyan
    Write-Host ("=" * 85) -ForegroundColor White

    # ตารางที่ 1: เฉพาะที่ตรงกับ Blacklist (ถ้ามี)
    if ($foundInBlacklist.Count -gt 0) {
        Write-Host "[!] ตรวจพบคำต้องห้ามในชื่อไวรัส (CRITICAL FOUND)" -ForegroundColor Red -BackgroundColor Black
        $foundInBlacklist | Format-Table -AutoSize
        Write-Host ">>> สรุป: พบคำต้องห้าม! ไม่แนะนำให้ใช้ไฟล์นี้ <<<" -ForegroundColor Red
    } else {
        Write-Host "[+] ไม่พบคำต้องห้ามตามลิสต์ที่คุณกำหนดไว้" -ForegroundColor Green
    }

    Write-Host ("-" * 85) -ForegroundColor Gray

    # ตารางที่ 2: รายชื่อไวรัสทั้งหมดที่ตรวจเจอ (Full Table)
    Write-Host "[+] รายชื่อการตรวจพบทั้งหมด (จากทุกค่าย)" -ForegroundColor Yellow
    if ($allResults.Count -gt 0) {
        $allResults | Select-Object @{n='ANTIVIRUS ENGINE';e={$_.engine_name}}, @{n='DETECTION RESULT';e={$_.result}} | Format-Table -AutoSize
    } else {
        Write-Host " ไม่พบประวัติมัลแวร์ในฐานข้อมูล (Clean)" -ForegroundColor Green
    }

    # สรุปคะแนนท้ายตาราง
    $stats = $response.data.attributes.last_analysis_stats
    Write-Host ("=" * 85) -ForegroundColor White
    Write-Host "คะแนนความอันตราย: " -NoNewline
    Write-Host "$($stats.malicious)" -ForegroundColor Red -NoNewline
    Write-Host " จาก $($stats.malicious + $stats.undetected) ค่ายสแกน"
    Write-Host ("=" * 85) -ForegroundColor White

} catch {
    Write-Host "`n[-] ไม่พบข้อมูลไฟล์นี้ (ยังไม่มีใครเคยส่งสแกน) หรือ API Key ไม่ถูกต้อง" -ForegroundColor Yellow
}

Write-Host "`nกด Enter เพื่อปิดหน้าต่าง..."
Read-Host
