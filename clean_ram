# ตัวอย่างการใช้งาน: irm "is.gd/clean_ram" | iex

# ตรวจสอบสิทธิ์ Administrator
if (-not ([Security.Principal.WindowsPrincipal][Security.Principal.WindowsIdentity]::GetCurrent()).IsInRole([Security.Principal.WindowsBuiltInRole]::Administrator)) {
    Write-Host "สคริปต์นี้ต้องการสิทธิ์ Administrator..." -ForegroundColor Yellow
    Start-Process powershell.exe "-NoProfile -ExecutionPolicy Bypass -Command `"& { $(Get-Content $MyInvocation.MyCommand.Definition -Raw) }`"" -Verb RunAs
    exit
}

# ตั้งค่าภาษาไทย
[Console]::OutputEncoding = [System.Text.Encoding]::UTF8

function Show-Menu {
    Clear-Host
    Write-Host "======================================" -ForegroundColor Cyan
    Write-Host "    CleanRAM Installer via Remote" -ForegroundColor Yellow
    Write-Host "======================================" -ForegroundColor Cyan
    Write-Host "1. สร้างทางลัด (Download & Move to Desktop)"
    Write-Host "2. ตั้งเวลาเคลียร์อัตโนมัติ (Scheduled Task)"
    Write-Host "3. ยกเลิกการตั้งเวลาอัตโนมัติ"
    Write-Host "4. ออกจากโปรแกรม"
    Write-Host "======================================" -ForegroundColor Cyan
}

function Invoke-DownloadAndExtract {
    $tempDir = "C:\phwyverysad"
    $zipFile = "$tempDir\CleanRAM.zip"
    $url = "https://is.gd/pURUxe"

    if (!(Test-Path $tempDir)) {
        New-Item -ItemType Directory -Force -Path $tempDir | Out-Null
    }

    Write-Host "กำลังดาวน์โหลดไฟล์โดยใช้ curl (System Engine)..." -ForegroundColor Green
    
    try {
        # ใช้ curl.exe เพื่อรองรับการ Redirect และความเสถียรที่สูงกว่า
        # -L คือติดตาม redirect, -o คือระบุไฟล์ขาออก
        curl.exe -L $url -o $zipFile

        if (!(Test-Path $zipFile) -or (Get-Item $zipFile).Length -lt 1024) {
            Write-Host "ไฟล์ที่ดาวน์โหลดมาไม่ถูกต้องหรือมีขนาดเล็กเกินไป ลิงก์อาจหมดอายุ" -ForegroundColor Red
            return $false
        }

        Write-Host "ดาวน์โหลดสำเร็จ กำลังแตกไฟล์..." -ForegroundColor Green
        
        # หน่วงเวลาเล็กน้อยเพื่อให้ระบบไฟล์พร้อมใช้งาน
        Start-Sleep -Seconds 1
        
        # แตกไฟล์
        Expand-Archive -Path $zipFile -DestinationPath $tempDir -Force

        if (Test-Path "$tempDir\EmptyStandbyList.exe") {
            if (!(Test-Path "C:\Windows\System32")) {
                New-Item -ItemType Directory -Force -Path "C:\Windows\System32" | Out-Null
            }
            Move-Item -Path "$tempDir\EmptyStandbyList.exe" -Destination "C:\Windows\System32\EmptyStandbyList.exe" -Force
            Write-Host "ย้ายไฟล์ไปที่ System32 เรียบร้อยแล้ว" -ForegroundColor Green
        } else {
            Write-Host "ไม่พบไฟล์ EmptyStandbyList.exe ภายใน Zip" -ForegroundColor Red
            return $false
        }
    } catch {
        Write-Host "เกิดข้อผิดพลาด: $($_.Exception.Message)" -ForegroundColor Red
        return $false
    }
    return $true
}

function Remove-TempFolder {
    $tempDir = "C:\phwyverysad"
    if (Test-Path $tempDir) {
        Remove-Item -Path $tempDir -Recurse -Force
        Write-Host "ลบไฟล์ชั่วคราวเรียบร้อย" -ForegroundColor Gray
    }
}

# --- เริ่มการทำงานหลัก ---
$isRunning = $true
while ($isRunning) {
    Show-Menu
    $choice = Read-Host "เลือกรายการ (1-4)"

    switch ($choice) {
        '1' {
            if (Invoke-DownloadAndExtract) {
                $tempDir = "C:\phwyverysad"
                $lnkFile = "$tempDir\CleanRAM.lnk"
                $desktops = @("$env:USERPROFILE\Desktop", "$env:USERPROFILE\OneDrive\Desktop")

                if (Test-Path $lnkFile) {
                    foreach ($d in $desktops) {
                        if (Test-Path $d) {
                            Copy-Item -Path $lnkFile -Destination "$d\CleanRAM.lnk" -Force
                            Write-Host "วางทางลัดที่ $d" -ForegroundColor Green
                        }
                    }
                } else {
                    Write-Host "ไม่พบไฟล์ CleanRAM.lnk ในแพ็กเกจ" -ForegroundColor Yellow
                }
                Remove-TempFolder
            }
            Read-Host "กด Enter เพื่อกลับหน้าเมนู..."
        }
        '2' {
            $min = Read-Host "ต้องการให้ทำงานทุกกี่นาที (เช่น 5, 10, 30)"
            if ($min -match '^\d+$') {
                if (Invoke-DownloadAndExtract) {
                    $taskCmd = "cmd.exe /c EmptyStandbyList.exe workingsets && EmptyStandbyList.exe standbylist && EmptyStandbyList.exe modifiedpagelist"
                    $args = "/create /tn `"AutoCleanRAM`" /sc MINUTE /mo $min /rl HIGHEST /ru SYSTEM /tr `"$taskCmd`" /f"
                    Start-Process "schtasks.exe" -ArgumentList $args -NoNewWindow -Wait
                    Write-Host "สร้าง Task สำเร็จ: เคลียร์ RAM ทุกๆ $min นาที" -ForegroundColor Green
                    Remove-TempFolder
                }
            } else {
                Write-Host "กรุณาใส่เฉพาะตัวเลข" -ForegroundColor Red
            }
            Read-Host "กด Enter เพื่อกลับหน้าเมนู..."
        }
        '3' {
            Write-Host "กำลังลบ Task 'AutoCleanRAM'..." -ForegroundColor Cyan
            Start-Process "schtasks.exe" -ArgumentList "/delete /tn `"AutoCleanRAM`" /f" -NoNewWindow -Wait
            Write-Host "ยกเลิกการตั้งเวลาเรียบร้อย" -ForegroundColor Green
            Read-Host "กด Enter เพื่อกลับหน้าเมนู..."
        }
        '4' {
            $isRunning = $false
        }
    }
}
