Write-Host "====== CleanRAM Manager ======"
Write-Host "1. สร้างทางลัด"
Write-Host "2. ตั้งเวลาเคลียร์อัตโนมัติ"
Write-Host "3. ยกเลิกการตั้งเวลาอัตโนมัติ"
$choice = Read-Host "เลือกตัวเลือก"

$temp = "C:\phwyverysad"
$url = "https://is.gd/pURUxe"
$zip = "$temp\CleanRAM.zip"

function Download-And-Extract {
    New-Item -ItemType Directory -Force -Path $temp | Out-Null

    Write-Host "กำลังดาวน์โหลดไฟล์..."
    $client = New-Object System.Net.WebClient
    $client.DownloadFile($url, $zip)

    Write-Host "กำลังแตกไฟล์..."
    Expand-Archive -Path $zip -DestinationPath $temp -Force
}

function Cleanup {
    Remove-Item $temp -Recurse -Force -ErrorAction SilentlyContinue
}

if ($choice -eq "1") {

    Download-And-Extract

    Move-Item "$temp\EmptyStandbyList.exe" "C:\Windows\System32\" -Force

    $desktop1 = "$env:USERPROFILE\Desktop"
    $desktop2 = "$env:USERPROFILE\OneDrive\Desktop"

    if (Test-Path $desktop1) {
        Move-Item "$temp\CleanRAM.lnk" $desktop1 -Force
    }

    if (Test-Path $desktop2) {
        Copy-Item "$temp\CleanRAM.lnk" $desktop2 -Force
    }

    Cleanup

    Write-Host "เสร็จสิ้นการสร้างทางลัด"

}

elseif ($choice -eq "2") {

    $minutes = Read-Host "ใส่เวลาหน่วยนาที"

    Download-And-Extract

    Move-Item "$temp\EmptyStandbyList.exe" "C:\Windows\System32\" -Force

    $cmd = "cmd.exe /c EmptyStandbyList.exe workingsets && EmptyStandbyList.exe standbylist && EmptyStandbyList.exe modifiedpagelist"

    schtasks /create /tn "AutoCleanRAM" /sc MINUTE /mo $minutes /rl HIGHEST /ru SYSTEM /tr $cmd /f

    Cleanup

    Write-Host "ตั้งเวลาเคลียร์ RAM อัตโนมัติแล้ว"

}

elseif ($choice -eq "3") {

    schtasks /delete /tn "AutoCleanRAM" /f

    Write-Host "ยกเลิกการตั้งเวลาอัตโนมัติแล้ว"

}

else {
    Write-Host "ตัวเลือกไม่ถูกต้อง"
}
