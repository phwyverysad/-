# ================================================
# สคริปต์ PowerShell สำหรับจัดการ CleanRAM
# รันด้วยสิทธิ์ Administrator เท่านั้น
# ================================================

# ตรวจสอบสิทธิ์ Administrator
if (-not ([Security.Principal.WindowsPrincipal][Security.Principal.WindowsIdentity]::GetCurrent()).IsInRole([Security.Principal.WindowsBuiltInRole]::Administrator)) {
    Write-Host "❌ กรุณารันสคริปต์นี้ด้วยสิทธิ์ Administrator (Run as Administrator)" -ForegroundColor Red
    Read-Host "กด Enter เพื่อปิด"
    exit
}

Clear-Host
Write-Host "=== โปรแกรมจัดการ CleanRAM ===" -ForegroundColor Cyan
Write-Host "1. สร้างทางลัด (Shortcut)"
Write-Host "2. ตั้งเวลาเคลียร์ RAM อัตโนมัติ"
Write-Host "3. ยกเลิกการตั้งเวลาอัตโนมัติ"
Write-Host "=================================" -ForegroundColor Cyan

$choice = Read-Host "เลือกตัวเลือก (1, 2 หรือ 3)"

$folder = "C:\phwyverysad"
$zipPath = "$folder\CleanRAM.zip"
$downloadUrl = "https://is.gd/pURUxe"

switch ($choice) {
    "1" {
        Write-Host "`nกำลังดำเนินการสร้างทางลัด..." -ForegroundColor Green
        
        # ลบโฟลเดอร์เก่าถ้ามี
        if (Test-Path $folder) { Remove-Item -Path $folder -Recurse -Force -ErrorAction SilentlyContinue }
        
        # สร้างโฟลเดอร์
        New-Item -ItemType Directory -Path $folder -Force | Out-Null
        
        # ดาวน์โหลดด้วย .NET (ตามที่ขอ)
        Write-Host "กำลังดาวน์โหลด CleanRAM.zip..."
        $webClient = New-Object System.Net.WebClient
        $webClient.DownloadFile($downloadUrl, $zipPath)
        
        # แตกไฟล์
        Write-Host "กำลังแตกไฟล์..."
        Expand-Archive -Path $zipPath -DestinationPath $folder -Force
        
        # ย้าย EmptyStandbyList.exe ไป System32
        if (Test-Path "$folder\EmptyStandbyList.exe") {
            Move-Item -Path "$folder\EmptyStandbyList.exe" -Destination "C:\Windows\System32\" -Force
            Write-Host "✓ ย้าย EmptyStandbyList.exe ไป System32 เรียบร้อย" -ForegroundColor Green
        }
        
        # ย้ายลิงก์ไปทั้ง 2 Desktop (คัดลอกเพื่อให้มีทั้งคู่)
        $lnkPath = "$folder\CleanRAM.lnk"
        if (Test-Path $lnkPath) {
            Copy-Item -Path $lnkPath -Destination "$env:USERPROFILE\Desktop\" -Force
            $oneDriveDesktop = "$env:USERPROFILE\OneDrive\Desktop"
            if (Test-Path $oneDriveDesktop) {
                Copy-Item -Path $lnkPath -Destination $oneDriveDesktop -Force
            }
            Write-Host "✓ วางทางลัด CleanRAM.lnk บน Desktop (และ OneDrive Desktop) เรียบร้อย" -ForegroundColor Green
        }
        
        # ลบโฟลเดอร์ชั่วคราว
        Remove-Item -Path $folder -Recurse -Force
        Write-Host "`n✅ เสร็จสิ้น! สร้างทางลัดเรียบร้อยแล้ว" -ForegroundColor Green
    }
    
    "2" {
        $minutes = Read-Host "`nกรุณาใส่จำนวนเวลาเคลียร์ (หน่วย: นาที)"
        
        if (-not $minutes -or $minutes -notmatch '^\d+$') {
            Write-Host "❌ กรุณาใส่ตัวเลขเท่านั้น" -ForegroundColor Red
            Read-Host "กด Enter เพื่อปิด"
            exit
        }
        
        Write-Host "`nกำลังตั้งเวลาเคลียร์ทุก $minutes นาที..." -ForegroundColor Green
        
        # ลบโฟลเดอร์เก่าถ้ามี
        if (Test-Path $folder) { Remove-Item -Path $folder -Recurse -Force -ErrorAction SilentlyContinue }
        
        # สร้างโฟลเดอร์
        New-Item -ItemType Directory -Path $folder -Force | Out-Null
        
        # ดาวน์โหลดด้วย .NET
        Write-Host "กำลังดาวน์โหลด CleanRAM.zip..."
        $webClient = New-Object System.Net.WebClient
        $webClient.DownloadFile($downloadUrl, $zipPath)
        
        # แตกไฟล์
        Write-Host "กำลังแตกไฟล์..."
        Expand-Archive -Path $zipPath -DestinationPath $folder -Force
        
        # ย้าย EmptyStandbyList.exe ไป System32
        if (Test-Path "$folder\EmptyStandbyList.exe") {
            Move-Item -Path "$folder\EmptyStandbyList.exe" -Destination "C:\Windows\System32\" -Force
            Write-Host "✓ ย้าย EmptyStandbyList.exe ไป System32 เรียบร้อย" -ForegroundColor Green
        }
        
        # สร้าง Scheduled Task
        Write-Host "กำลังสร้างงานอัตโนมัติ..."
        $taskCommand = "cmd.exe /c EmptyStandbyList.exe workingsets && EmptyStandbyList.exe standbylist && EmptyStandbyList.exe modifiedpagelist"
        Invoke-Expression "schtasks /create /tn `"AutoCleanRAM`" /sc MINUTE /mo $minutes /rl HIGHEST /ru SYSTEM /tr `"$taskCommand`" /f"
        
        # ลบโฟลเดอร์ชั่วคราว
        Remove-Item -Path $folder -Recurse -Force
        Write-Host "`n✅ เสร็จสิ้น! ตั้งเวลาเคลียร์ทุก $minutes นาทีเรียบร้อยแล้ว" -ForegroundColor Green
    }
    
    "3" {
        Write-Host "`nกำลังยกเลิกการตั้งเวลาอัตโนมัติ..." -ForegroundColor Yellow
        schtasks /delete /tn "AutoCleanRAM" /f 2>$null
        Write-Host "`n✅ เสร็จสิ้น! ยกเลิกงาน AutoCleanRAM เรียบร้อยแล้ว" -ForegroundColor Green
    }
    
    default {
        Write-Host "`n❌ เลือกตัวเลือกไม่ถูกต้อง" -ForegroundColor Red
    }
}

Write-Host "`nกด Enter เพื่อปิดหน้าต่าง..." -ForegroundColor Gray
Read-Host
