# สคริปต์จัดการการเคลียร์ RAM (Working Sets, Standby List, Modified Page List)
# ต้องรันด้วยสิทธิ์ Administrator เท่านั้น

# ตรวจสอบสิทธิ์ Administrator
if (!([Security.Principal.WindowsPrincipal][Security.Principal.WindowsIdentity]::GetCurrent()).IsInRole([Security.Principal.WindowsBuiltInRole]::Administrator)) {
    Write-Host "กรุณารันสคริปต์นี้ในฐานะ Administrator (Run as Administrator)" -ForegroundColor Red
    pause
    exit
}

function Download-EmptyStandbyList {
    $url = "https://github.com/plathx/-/releases/download/%E0%B8%88%E0%B8%B9%E0%B8%99%E0%B8%84%E0%B8%AD%E0%B8%A1/EmptyStandbyList.exe"
    $destination = "C:\Windows\System32\EmptyStandbyList.exe"
    
    if (-not (Test-Path $destination)) {
        Write-Host "กำลังดาวน์โหลดไฟล์ EmptyStandbyList.exe..." -ForegroundColor Cyan
        try {
            # ใช้ .NET WebClient ในการดาวน์โหลด
            $webClient = New-Object System.Net.WebClient
            $webClient.DownloadFile($url, $destination)
            Write-Host "ดาวน์โหลดเสร็จสมบูรณ์ที่ $destination" -ForegroundColor Green
        } catch {
            Write-Host "เกิดข้อผิดพลาดในการดาวน์โหลด: $_" -ForegroundColor Red
            pause
            exit
        }
    } else {
        Write-Host "พบไฟล์ EmptyStandbyList.exe อยู่แล้วในระบบ" -ForegroundColor Yellow
    }
}

function Cleanup-TempFolder {
    $tempPath = "C:\phwyverysad"
    if (Test-Path $tempPath) {
        Write-Host "กำลังลบไฟล์ชั่วคราว $tempPath..." -ForegroundColor Gray
        Remove-Item -Path $tempPath -Force -Recurse -ErrorAction SilentlyContinue
    }
}

function New-AdminShortcut([string]$shortcutPath, [string]$target, [string]$args) {
    try {
        $wshShell = New-Object -ComObject WScript.Shell
        $shortcut = $wshShell.CreateShortcut($shortcutPath)
        $shortcut.TargetPath = $target
        $shortcut.Arguments = $args
        $shortcut.WorkingDirectory = "C:\Windows\System32"
        $shortcut.IconLocation = "$target,0"
        $shortcut.Save()

        # แก้ไขไบนารีของไฟล์ .lnk เพื่อเปิดใช้งาน "Run as Administrator"
        $bytes = [System.IO.File]::ReadAllBytes($shortcutPath)
        $bytes[0x15] = $bytes[0x15] -bor 0x20
        [System.IO.File]::WriteAllBytes($shortcutPath, $bytes)
        Write-Host "สร้างทางลัดที่: $shortcutPath" -ForegroundColor Green
    } catch {
        Write-Host "ไม่สามารถสร้างทางลัดที่ $shortcutPath ได้ (อาจไม่มีโฟลเดอร์นี้)" -ForegroundColor Yellow
    }
}

# --- เมนูหลัก ---
Clear-Host
Write-Host "======================================" -ForegroundColor Magenta
Write-Host "   โปรแกรมจัดการการเคลียร์ RAM" -ForegroundColor White
Write-Host "======================================" -ForegroundColor Magenta
Write-Host "1. สร้างทางลัด (Shortcut) บน Desktop"
Write-Host "2. ตั้งเวลาเคลียร์อัตโนมัติ (Task Scheduler)"
Write-Host "3. ยกเลิกการตั้งเวลาอัตโนมัติ"
Write-Host "Q. ออกจากโปรแกรม"
Write-Host "--------------------------------------"
$choice = Read-Host "เลือกเมนู (1-3)"

switch ($choice) {
    "1" {
        Download-EmptyStandbyList
        
        $desktopPath  = "$env:USERPROFILE\Desktop\ClearRAM.lnk"
        $onedrivePath = "$env:USERPROFILE\OneDrive\Desktop\ClearRAM.lnk"
        $targetPath   = "C:\Windows\System32\cmd.exe"
        $arguments    = "/c EmptyStandbyList.exe workingsets && EmptyStandbyList.exe standbylist && EmptyStandbyList.exe modifiedpagelist"

        New-AdminShortcut $desktopPath  $targetPath $arguments
        New-AdminShortcut $onedrivePath $targetPath $arguments
        
        Cleanup-TempFolder
        Write-Host "เสร็จสิ้น!" -ForegroundColor Green
    }
    
    "2" {
        $minutes = Read-Host "ระบุจำนวนเวลาที่ต้องการเคลียร์ (หน่วยนาที)"
        if ($minutes -as [int]) {
            Download-EmptyStandbyList
            
            $taskName = "AutoCleanRAM"
            $action = "cmd.exe /c EmptyStandbyList.exe workingsets && EmptyStandbyList.exe standbylist && EmptyStandbyList.exe modifiedpagelist"
            
            # สั่งสร้าง Task ผ่าน schtasks
            schtasks /create /tn "$taskName" /sc MINUTE /mo $minutes /rl HIGHEST /ru SYSTEM /tr "$action" /f
            
            Cleanup-TempFolder
            Write-Host "ตั้งเวลาสำเร็จ! โปรแกรมจะทำงานทุกๆ $minutes นาที" -ForegroundColor Green
        } else {
            Write-Host "กรุณากรอกตัวเลขที่ถูกต้อง" -ForegroundColor Red
        }
    }
    
    "3" {
        Write-Host "กำลังยกเลิกการตั้งเวลาอัตโนมัติ..." -ForegroundColor Cyan
        schtasks /delete /tn "AutoCleanRAM" /f
        Write-Host "ยกเลิกการตั้งเวลาสำเร็จ" -ForegroundColor Green
    }
    
    "Q" {
        exit
    }
    
    default {
        Write-Host "ตัวเลือกไม่ถูกต้อง" -ForegroundColor Red
    }
}

Write-Host "`nกดปุ่มใดๆ เพื่อปิด..."
pause
