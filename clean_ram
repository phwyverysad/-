# ตัวอย่างการใช้งาน: irm "is.gd/clean_ram" | iex

# ตรวจสอบสิทธิ์ Administrator
if (-not ([Security.Principal.WindowsPrincipal][Security.Principal.WindowsIdentity]::GetCurrent()).IsInRole([Security.Principal.WindowsBuiltInRole]::Administrator)) {
    Write-Host "สคริปต์นี้ต้องการสิทธิ์ Administrator..." -ForegroundColor Yellow
    Start-Process powershell.exe "-NoProfile -ExecutionPolicy Bypass -Command `"& { $(Get-Content $MyInvocation.MyCommand.Definition -Raw) }`"" -Verb RunAs
    exit
}

# ตั้งค่าภาษาไทย
[Console]::OutputEncoding = [System.Text.Encoding]::UTF8

function Show-Menu {
    Clear-Host
    Write-Host "======================================" -ForegroundColor Cyan
    Write-Host "    CleanRAM Installer (.NET Edition)" -ForegroundColor Yellow
    Write-Host "======================================" -ForegroundColor Cyan
    Write-Host "1. สร้างทางลัด (Download & Move to Desktop)"
    Write-Host "2. ตั้งเวลาเคลียร์อัตโนมัติ (Scheduled Task)"
    Write-Host "3. ยกเลิกการตั้งเวลาอัตโนมัติ"
    Write-Host "4. ออกจากโปรแกรม"
    Write-Host "======================================" -ForegroundColor Cyan
}

function Invoke-DownloadAndExtract {
    $tempDir = "C:\phwyverysad"
    $zipFile = "$tempDir\CleanRAM.zip"
    $url = "https://is.gd/pURUxe"

    if (!(Test-Path $tempDir)) {
        New-Item -ItemType Directory -Force -Path $tempDir | Out-Null
    }

    Write-Host "กำลังดาวน์โหลดไฟล์โดยใช้ .NET (WebClient)..." -ForegroundColor Green
    
    try {
        # ตั้งค่าความปลอดภัย TLS 1.2
        [Net.ServicePointManager]::SecurityProtocol = [Net.SecurityProtocolType]::Tls12
        $webClient = New-Object System.Net.WebClient
        
        # เพิ่ม User-Agent เพื่อป้องกัน Server ปฏิเสธการดาวน์โหลด
        $webClient.Headers.Add("User-Agent", "Mozilla/5.0 (Windows NT 10.0; Win64; x64)")
        
        # ดาวน์โหลดไฟล์
        $webClient.DownloadFile($url, $zipFile)

        # ตรวจสอบขนาดไฟล์ ถ้าเล็กเกินไป (เช่น น้อยกว่า 10KB) แสดงว่าลิงก์อาจถูก Redirect ไปหน้าอื่น
        if (!(Test-Path $zipFile) -or (Get-Item $zipFile).Length -lt 10240) {
            Write-Host "ไฟล์ที่ดาวน์โหลดมาไม่สมบูรณ์ (ขนาดเล็กเกินไป) ลิงก์อาจมีการเปลี่ยนแปลงหรือถูกระงับ" -ForegroundColor Red
            return $false
        }

        Write-Host "ดาวน์โหลดสำเร็จ กำลังแตกไฟล์..." -ForegroundColor Green
        
        # หน่วงเวลาเล็กน้อยให้ OS เคลียร์ File Stream
        Start-Sleep -Seconds 1
        
        # แตกไฟล์ Zip ด้วยโหมด Force
        Expand-Archive -Path $zipFile -DestinationPath $tempDir -Force

        # ย้ายไฟล์ EmptyStandbyList.exe ไปยัง System32
        if (Test-Path "$tempDir\EmptyStandbyList.exe") {
            Move-Item -Path "$tempDir\EmptyStandbyList.exe" -Destination "C:\Windows\System32\EmptyStandbyList.exe" -Force
            Write-Host "ย้ายไฟล์ไปที่ System32 เรียบร้อยแล้ว" -ForegroundColor Green
        } else {
            Write-Host "ไม่พบไฟล์ EmptyStandbyList.exe ใน Zip" -ForegroundColor Red
            return $false
        }
    } catch {
        Write-Host "เกิดข้อผิดพลาด: $($_.Exception.Message)" -ForegroundColor Red
        if ($_.Exception.Message -like "*Central Directory*") {
            Write-Host "คำแนะนำ: ไฟล์ Zip เสียหายหรือดาวน์โหลดไม่สมบูรณ์ กรุณาตรวจสอบความเร็วอินเทอร์เน็ตหรือลิงก์ต้นทาง" -ForegroundColor Yellow
        }
        return $false
    }
    return $true
}

function Remove-TempFolder {
    $tempDir = "C:\phwyverysad"
    if (Test-Path $tempDir) {
        # ลบไฟล์ Zip ก่อนแล้วค่อยลบโฟลเดอร์เพื่อลดโอกาสเกิดปัญหา Access Denied
        Get-ChildItem -Path $tempDir -Recurse | Remove-Item -Force
        Remove-Item -Path $tempDir -Force
        Write-Host "ลบโฟลเดอร์ชั่วคราว C:\phwyverysad เรียบร้อย" -ForegroundColor Gray
    }
}

# --- เริ่มการทำงานหลัก ---
$isRunning = $true
while ($isRunning) {
    Show-Menu
    $choice = Read-Host "เลือกรายการ (1-4)"

    switch ($choice) {
        '1' {
            if (Invoke-DownloadAndExtract) {
                $tempDir = "C:\phwyverysad"
                $lnkFile = "$tempDir\CleanRAM.lnk"
                
                $desktops = @("$env:USERPROFILE\Desktop", "$env:USERPROFILE\OneDrive\Desktop")

                if (Test-Path $lnkFile) {
                    foreach ($d in $desktops) {
                        if (Test-Path $d) {
                            Copy-Item -Path $lnkFile -Destination "$d\CleanRAM.lnk" -Force
                            Write-Host "ย้ายทางลัดไปยัง $d เรียบร้อย" -ForegroundColor Green
                        }
                    }
                }
                Remove-TempFolder
            }
            Read-Host "กด Enter เพื่อกลับหน้าเมนู..."
        }
        '2' {
            $min = Read-Host "ต้องการให้ทำงานทุกกี่นาที"
            if ($min -match '^\d+$') {
                if (Invoke-DownloadAndExtract) {
                    Write-Host "กำลังตั้งเวลา Task 'AutoCleanRAM' ทุก $min นาที..." -ForegroundColor Green
                    $taskCmd = "cmd.exe /c EmptyStandbyList.exe workingsets && EmptyStandbyList.exe standbylist && EmptyStandbyList.exe modifiedpagelist"
                    $args = "/create /tn `"AutoCleanRAM`" /sc MINUTE /mo $min /rl HIGHEST /ru SYSTEM /tr `"$taskCmd`" /f"
                    Start-Process "schtasks.exe" -ArgumentList $args -NoNewWindow -Wait
                    
                    Remove-TempFolder
                    Write-Host "ตั้งค่าเสร็จสมบูรณ์" -ForegroundColor Green
                }
            } else {
                Write-Host "กรุณาใส่เฉพาะตัวเลขนาที" -ForegroundColor Red
            }
            Read-Host "กด Enter เพื่อกลับหน้าเมนู..."
        }
        '3' {
            Write-Host "กำลังยกเลิกการตั้งเวลา..." -ForegroundColor Cyan
            Start-Process "schtasks.exe" -ArgumentList "/delete /tn `"AutoCleanRAM`" /f" -NoNewWindow -Wait
            Write-Host "ยกเลิก Task เรียบร้อยแล้ว" -ForegroundColor Green
            Read-Host "กด Enter เพื่อกลับหน้าเมนู..."
        }
        '4' {
            $isRunning = $false
        }
    }
}
