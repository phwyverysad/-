<#
.SYNOPSIS
    High-Performance OS Playbook Downloader (Expert Edition)
    Optimized for: Multi-threading, Low-latency Networking, and Direct I/O.
#>

$ErrorActionPreference = "Stop"

# 1. Networking & Protocol Optimization
[Net.ServicePointManager]::SecurityProtocol = [Net.SecurityProtocolType]::Tls12 -bor [Net.SecurityProtocolType]::Tls13
$handler = New-Object System.Net.Http.SocketsHttpHandler
$handler.PooledConnectionLifetime = New-TimeSpan -Minutes 5
$handler.MaxConnectionsPerServer = 10
$httpClient = New-Object System.Net.Http.HttpClient($handler)

# 2-4. Implementation Logic (Execution, Memory, Storage)
Function Start-HighSpeedDownload {
    param(
        [Parameter(Mandatory=$true)][string]$Url,
        [Parameter(Mandatory=$true)][string]$FileName
    )

    $DestPath = Join-Path $ScriptDir $FileName
    Write-Host ">>> Initiating: $FileName" -ForegroundColor Cyan

    try {
        # Request Headers for Keep-Alive and Optimization
        $request = New-Object System.Net.Http.HttpRequestMessage([System.Net.Http.HttpMethod]::Get, $Url)
        $responseTask = $httpClient.SendAsync($request, [System.Net.Http.HttpCompletionOption]::ResponseHeadersRead)
        $response = $responseTask.GetAwaiter().GetResult()
        $response.EnsureSuccessStatusCode() | Out-Null

        $totalBytes = $response.Content.Headers.ContentLength
        $sourceStream = $response.Content.ReadAsStreamAsync().GetAwaiter().GetResult()

        # 4. Disk Space Pre-allocation
        $fileStream = New-Object System.IO.FileStream($DestPath, [System.IO.FileMode]::Create, [System.IO.FileAccess]::Write, [System.IO.FileShare]::None, 1048576, [System.IO.FileOptions]::Asynchronous)
        if ($totalBytes) {
            $fileStream.SetLength($totalBytes) # Pre-allocate disk space
        }

        # 3. Optimized Buffer Stream (1MB)
        $buffer = New-Object byte[] 1048576 # 1MB Buffer
        $count = 0
        while (($count = $sourceStream.Read($buffer, 0, $buffer.Length)) -gt 0) {
            $fileStream.Write($buffer, 0, $count)
        }

        $fileStream.Flush()
        $fileStream.Dispose()
        $sourceStream.Dispose()
        
        Write-Host " [SUCCESS] $FileName" -ForegroundColor Green
    }
    catch {
        Write-Host " [FAILED] $($_.Exception.Message)" -ForegroundColor Red
    }
}

# --- UI & Selection Logic ---
if ($MyInvocation.MyCommand.Path) { $ScriptDir = Split-Path -Parent $MyInvocation.MyCommand.Path } else { $ScriptDir = $PWD }
Set-Location $ScriptDir

$AME_URL = "https://github.com/Ameliorated-LLC/trusted-uninstaller-cli/releases/download/0.8.4/AME-Beta-v0.8.4.exe"
$REVI_URL = "https://github.com/meetrevision/playbook/releases/download/25.10/Revi-PB-25.10.apbx"

Clear-Host
Write-Host "===================================================" -ForegroundColor Magenta
Write-Host "       CORE-OPTIMIZED PLAYBOOK DOWNLOADER"         -ForegroundColor Magenta
Write-Host "===================================================" -ForegroundColor Magenta
Write-Host "[1] Full Suite (AME + Atlas + Revi)"
Write-Host "[2] AtlasOS"
Write-Host "[3] ReviOS"
Write-Host "[4] AME Beta"
Write-Host "---------------------------------------------------"
$choice = Read-Host "Enter Selection"

$queue = New-Object System.Collections.Generic.List[PSCustomObject]

# Mapping Atlas versions
if ($choice -in '1','2') {
    Write-Host "`nSelect AtlasOS Version:`n[1] 24H2/25H2  [2] 23H2  [3] Win10 22H2" -ForegroundColor Yellow
    $v = Read-Host "Ver"
    $atlas = switch($v){
        "1" {@("https://github.com/Atlas-OS/Atlas/releases/download/0.5.0-hotfix/AtlasPlaybook_v0.5.0-hotfix.apbx", "AtlasPlaybook_v0.5.0.apbx")}
        "2" {@("https://github.com/Atlas-OS/Atlas/releases/download/0.4.1/AtlasPlaybook_v0.4.1.apbx", "AtlasPlaybook_v0.4.1.apbx")}
        "3" {@("https://github.com/Atlas-OS/Atlas/releases/download/0.4.0/AtlasPlaybook_v0.4.0.apbx", "AtlasPlaybook_v0.4.0.apbx")}
    }
}

# Queue building
if ($choice -eq '1' -or $choice -eq '4') { $queue.Add([PSCustomObject]@{Url=$AME_URL; Name="AME-v0.8.4.exe"}) }
if ($choice -eq '1' -or $choice -eq '2') { if($atlas){ $queue.Add([PSCustomObject]@{Url=$atlas[0]; Name=$atlas[1]}) } }
if ($choice -eq '1' -or $choice -eq '3') { $queue.Add([PSCustomObject]@{Url=$REVI_URL; Name="Revi-PB-25.10.apbx"}) }

# Execute Multi-threaded Parallelism
Clear-Host
Write-Host ">>> Starting Parallel Execution Stage..." -ForegroundColor Yellow
$queue | ForEach-Object -Parallel {
    # ปรับจูน Scope ภายใน Parallel
    $using:Action = { Start-HighSpeedDownload -Url $args[0] -FileName $args[1] }
    &$using:Action $PSItem.Url $PSItem.Name
} -ThrottleLimit 4

Write-Host "`nAll operations completed. Resources released." -ForegroundColor Green
explorer $ScriptDir
