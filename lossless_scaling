# กำหนดพาธของโฟลเดอร์ทำงาน
$workingDir = "C:\phwyverysad"
$zipPath = Join-Path $workingDir "lossless_scaling.zip"
$url = "https://github.com/plathx/-/releases/download/%E0%B8%88%E0%B8%B9%E0%B8%99%E0%B8%84%E0%B8%AD%E0%B8%A1/lossless_scaling.zip"

# 1. สร้างโฟลเดอร์ C:\phwyverysad หากยังไม่มี
if (!(Test-Path $workingDir)) {
    New-Item -ItemType Directory -Path $workingDir | Out-Null
    Write-Host "Created directory: $workingDir" -ForegroundColor Cyan
}

# 2. ดาวน์โหลดไฟล์โดยใช้ .NET (WebClient)
Write-Host "Downloading lossless_scaling.zip..." -ForegroundColor Yellow
try {
    $webClient = New-Object System.Net.WebClient
    $webClient.DownloadFile($url, $zipPath)
    Write-Host "Download complete." -ForegroundColor Green
} catch {
    Write-Host "Failed to download file: $_" -ForegroundColor Red
    exit
}

# 3. แตกไฟล์ zip
Write-Host "Extracting files..." -ForegroundColor Yellow
$extractTemp = Join-Path $workingDir "temp_extract"
Expand-Archive -Path $zipPath -DestinationPath $extractTemp -Force

# 4. ย้ายไฟล์ INSTALL.cmd จากโฟลเดอร์ Shortcut Setup มาไว้ที่ C:\phwyverysad
$sourceCmd = Join-Path $extractTemp "Shortcut Setup\INSTALL.cmd"
if (Test-Path $sourceCmd) {
    Move-Item -Path $sourceCmd -Destination $workingDir -Force
    Write-Host "Moved INSTALL.cmd to $workingDir" -ForegroundColor Green
} else {
    Write-Host "Could not find INSTALL.cmd in the expected subfolder." -ForegroundColor Red
}

# 5. ลบไฟล์ zip และโฟลเดอร์ที่แตกออกมา (ยกเว้น INSTALL.cmd ที่ย้ายออกมาแล้ว)
Remove-Item -Path $zipPath -Force
Remove-Item -Path $extractTemp -Recurse -Force
Write-Host "Cleaned up temporary zip and folders." -ForegroundColor Gray

# 6. รัน INSTALL.cmd และรอจนกว่าจะปิดตัวลง
$cmdPath = Join-Path $workingDir "INSTALL.cmd"
if (Test-Path $cmdPath) {
    Write-Host "Running INSTALL.cmd... Please wait for it to finish." -ForegroundColor Magenta
    $process = Start-Process -FilePath "cmd.exe" -ArgumentList "/c `"$cmdPath`"" -Wait -PassThru
    Write-Host "INSTALL.cmd has finished execution." -ForegroundColor Green
}

# 7. ลบโฟลเดอร์ C:\phwyverysad
Write-Host "Removing working directory: $workingDir" -ForegroundColor Yellow
Set-Location C:\ # ย้ายออกจากโฟลเดอร์ก่อนลบเพื่อไม่ให้เกิดการล็อคไฟล์
Remove-Item -Path $workingDir -Recurse -Force
Write-Host "All tasks completed successfully." -ForegroundColor Green
