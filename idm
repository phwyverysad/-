# กำหนดเส้นทางโฟลเดอร์ทำงาน
$targetPath = "C:\phwyverysad"
$zipFile = "$targetPath\idm_pro.zip"
$url = "https://github.com/plathx/-/releases/download/%E0%B8%88%E0%B8%B9%E0%B8%99%E0%B8%84%E0%B8%AD%E0%B8%A1/idm_pro.zip"

# 1. สร้างโฟลเดอร์ C:\phwyverysad หากยังไม่มี
if (!(Test-Path $targetPath)) {
    New-Item -ItemType Directory -Path $targetPath | Out-Null
    Write-Host "Created directory: $targetPath" -ForegroundColor Cyan
}

# 2. ดาวน์โหลดไฟล์โดยใช้ .NET (System.Net.WebClient)
Write-Host "Downloading idm_pro.zip..." -ForegroundColor Yellow
try {
    $webClient = New-Object System.Net.WebClient
    $webClient.DownloadFile($url, $zipFile)
    Write-Host "Download completed." -ForegroundColor Green
} catch {
    Write-Host "Error during download: $($_.Exception.Message)" -ForegroundColor Red
    exit
}

# 3. แตกไฟล์ idm_pro.zip
Write-Host "Extracting files..." -ForegroundColor Yellow
Expand-Archive -Path $zipFile -DestinationPath $targetPath -Force

# 4. ย้ายไฟล์ที่ระบุออกมาไว้ที่รูทของ C:\phwyverysad
$itemsToMove = @("INSTALL.cmd", "idman642build63.exe", "Crack")
foreach ($itemName in $itemsToMove) {
    $sourceItem = Get-ChildItem -Path $targetPath -Filter $itemName -Recurse | Select-Object -First 1
    if ($sourceItem) {
        $destPath = Join-Path $targetPath $itemName
        if ($sourceItem.FullName -ne $destPath) {
            Move-Item -Path $sourceItem.FullName -Destination $destPath -Force
        }
    }
}

# 5. ลบไฟล์ zip หลังจากแตกเสร็จแล้ว
if (Test-Path $zipFile) {
    Remove-Item -Path $zipFile -Force
    Write-Host "Removed zip file." -ForegroundColor Cyan
}

# 6. ตรวจสอบเบราว์เซอร์ที่เปิดอยู่
$browserProcesses = @("chrome", "msedge", "firefox", "brave", "opera")
$runningBrowsers = Get-Process | Where-Object { $browserProcesses -contains $_.ProcessName } | Select-Object -ExpandProperty Description -Unique

if ($runningBrowsers) {
    Write-Host "`nDetected running browsers:" -ForegroundColor Cyan
    foreach ($browser in $runningBrowsers) {
        Write-Host " - $browser" -ForegroundColor White
    }
    
    Write-Host "`n[!] กรุณาเซฟงานใน บราวเซอร์ แล้วกด Enter เพื่อบังคับปิด บราวเซอร์ ที่เปิดอยู่..." -ForegroundColor Yellow -NoNewline
    Read-Host
    
    # สั่งปิด Browser
    Write-Host "Closing browsers..." -ForegroundColor Red
    Get-Process | Where-Object { $browserProcesses -contains $_.ProcessName } | Stop-Process -Force
    Start-Sleep -Seconds 2
} else {
    Write-Host "No browsers detected running." -ForegroundColor Green
}

# 7. รัน INSTALL.cmd และรอจนกว่าจะปิดตัวลง
$cmdPath = Join-Path $targetPath "INSTALL.cmd"
if (Test-Path $cmdPath) {
    Write-Host "Running INSTALL.cmd... Please wait until it finishes." -ForegroundColor Magenta
    Start-Process -FilePath $cmdPath -WorkingDirectory $targetPath -Wait
    Write-Host "INSTALL.cmd has finished execution." -ForegroundColor Green
} else {
    Write-Host "Error: INSTALL.cmd not found!" -ForegroundColor Red
}

# 8. ลบโฟลเดอร์ C:\phwyverysad ทิ้งทั้งหมด
Write-Host "Cleaning up... Removing $targetPath" -ForegroundColor Yellow
if (Test-Path $targetPath) {
    Start-Sleep -Seconds 2
    Remove-Item -Path $targetPath -Recurse -Force
    Write-Host "Cleanup completed successfully." -ForegroundColor Green
}
