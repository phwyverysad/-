# 1. บังคับรันด้วยสิทธิ์ Administrator
if (!([Security.Principal.WindowsPrincipal][Security.Principal.WindowsIdentity]::GetCurrent()).IsInRole([Security.Principal.WindowsBuiltInRole]::Administrator)) {
    Start-Process powershell.exe "-NoProfile -ExecutionPolicy Bypass -File `"$PSCommandPath`"" -Verb RunAs
    Exit
}

# กำหนดตัวแปร
$dir = "C:\phwyverysad"
$url1 = "https://is.gd/dtF1gW"
$url2 = "https://is.gd/Fly5ky"
$file1 = "$dir\KernelOS.Performance.V6.1.IDLE.ON.pow"
$file2 = "$dir\UltimatePerformance.pow"

# ขั้นตอนแรก: สร้าง System Restore Point
Write-Host "กำลังสร้าง System Restore Point..." -ForegroundColor Cyan
Checkpoint-Computer -Description "Before Applying Performance Plans" -RestorePointType "MODIFY_SETTINGS"

# ขั้นตอนที่สอง: สร้างโฟลเดอร์
if (!(Test-Path $dir)) {
    New-Item -Path $dir -ItemType Directory | Out-Null
    Write-Host "สร้างโฟลเดอร์ $dir แล้ว" -ForegroundColor Green
}

# ดาวน์โหลดไฟล์
Write-Host "กำลังดาวน์โหลดไฟล์..." -ForegroundColor Yellow
Invoke-WebRequest -Uri $url1 -OutFile $file1
Invoke-WebRequest -Uri $url2 -OutFile $file2

# ขั้นตอนที่สาม: ติดตั้ง/Import Power Plans
Write-Host "กำลังติดตั้ง Power Plans..." -ForegroundColor Yellow
$plan1 = powercfg -import $file1
$plan2 = powercfg -import $file2

Write-Host "Import สำเร็จ:"
Write-Host $plan1
Write-Host $plan2

# ขั้นตอนสุดท้าย: ลบโฟลเดอร์
Write-Host "กำลังทำความสะอาดไฟล์ชั่วคราว..." -ForegroundColor Gray
Remove-Item -Path $dir -Recurse -Force
Write-Host "เสร็จสิ้นทุกขั้นตอน!" -ForegroundColor Green

Read-Host "กด Enter เพื่อปิดหน้าต่างนี้"
