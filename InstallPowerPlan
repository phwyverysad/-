# 1. ตรวจสอบสิทธิ์ Admin
if (-not ([Security.Principal.WindowsPrincipal][Security.Principal.WindowsIdentity]::GetCurrent()).IsInRole([Security.Principal.WindowsBuiltInRole] "Administrator")) {
    $arguments = "-NoProfile -ExecutionPolicy Bypass -File `"$PSCommandPath`""
    Start-Process powershell -ArgumentList $arguments -Verb RunAs
    exit
}

Write-Host "--- กำลังสร้าง System Restore Point (กรุณารอ...) ---" -ForegroundColor Cyan
try {
    Checkpoint-Computer -Description "Before Importing Power Plans" -RestorePointType "MODIFY_SETTINGS"
    Write-Host "สร้าง Restore Point เรียบร้อย" -ForegroundColor Green
} catch {
    Write-Host "ไม่สามารถสร้าง Restore Point ได้ (อาจปิดระบบนี้ไว้)" -ForegroundColor Yellow
}

# 2. ตั้งค่าโฟลเดอร์ทำงาน
$workDir = "$env:TEMP\PowerPlans"
if (Test-Path $workDir) { Remove-Item $workDir -Recurse -Force }
New-Item -ItemType Directory -Path $workDir | Out-Null
Set-Location $workDir

# 3. ดาวน์โหลดไฟล์
$files = @{
    "KernelOS.pow" = "https://is.gd/dtF1gW"
    "Ultimate.pow" = "https://is.gd/Fly5ky"
}

foreach ($name in $files.Keys) {
    Write-Host "กำลังดาวน์โหลด $name ..." -ForegroundColor Yellow
    Invoke-WebRequest -Uri $files[$name] -OutFile "$workDir\$name"
}

# 4. ฟังก์ชันดึง GUID หลัง Import
function Get-GuidFromImport {
    param([string]$FilePath)
    $output = powercfg -import "$FilePath"
    # ดึงค่าที่เป็น GUID ออกมา (รูปแบบ XXXXXXXX-XXXX-XXXX-XXXX-XXXXXXXXXXXX)
    $match = [regex]::Match($output, '\{[a-f0-9-]{36}\}')
    if ($match.Success) { return $match.Value.Trim('{}') }
    return $null
}

Write-Host "กำลังติดตั้ง Power Plans..." -ForegroundColor Green

$ultGuid = Get-GuidFromImport "$workDir\Ultimate.pow"
$kernGuid = Get-GuidFromImport "$workDir\KernelOS.pow"

# 5. ตั้งค่า Active เป็น Ultimate Performance
if ($ultGuid) {
    powercfg -setactive $ultGuid
    Write-Host "ติดตั้งและตั้งค่า Ultimate Performance สำเร็จ ($ultGuid)" -ForegroundColor Green
} else {
    Write-Host "เกิดข้อผิดพลาดในการ Import Ultimate Performance" -ForegroundColor Red
}

# 6. ลบไฟล์ชั่วคราว
Set-Location $env:USERPROFILE
Start-Sleep -Seconds 2
Remove-Item $workDir -Recurse -Force -ErrorAction SilentlyContinue

Write-Host "`nเสร็จสิ้น! กดปุ่มใดๆ เพื่อออกจากโปรแกรม..."
Read-Host
