$mcPath = "C:\XboxGames\Minecraft for Windows\Content\Minecraft.Windows.exe"
$targetDir = "C:\phwyverysad"
$zipPath = "$targetDir\minecraft_for_windows.zip"
$installerName = "KG UP - Mod Installer.exe"

if (-not (Test-Path $mcPath)) {
    Write-Host "ยังไม่มี Minecraft for Windows กรุณาดาวน์โหลดและติดตั้งให้เสร็จก่อนรัน irm is.gd/minecraft_for_windows | iex" -ForegroundColor Yellow
    Start-Sleep -Seconds 3
    Start-Process "ms-windows-store://pdp/?ProductId=9NBLGGH2JHXJ"
} else {
if (-not (Test-Path $targetDir)) { New-Item -Path $targetDir -ItemType Directory | Out-Null }

    Write-Host "กำลังดาวน์โหลดไฟล์..." -ForegroundColor Cyan
    $client = New-Object System.Net.WebClient
    $client.DownloadFile("https://is.gd/EHPP8o", $zipPath)

    Write-Host "กำลังแตกไฟล์..." -ForegroundColor Cyan
    Add-Type -AssemblyName System.IO.Compression.FileSystem
    [System.IO.Compression.ZipFile]::ExtractToDirectory($zipPath, $targetDir)

    $sourceDir = "$targetDir\minecraft_for_windows"
    $filesToMove = @($installerName, "MinecraftForFree.dll", "vcruntime140_1.dll")
    
    foreach ($file in $filesToMove) {
        if (Test-Path "$sourceDir\$file") {
            Move-Item -Path "$sourceDir\$file" -Destination $targetDir -Force
        }
    }

    Remove-Item -Path $zipPath -Force
    if (Test-Path $sourceDir) { Remove-Item -Path $sourceDir -Recurse -Force }

    Write-Host "กำลังรัน $installerName กรุณารอจนกว่าโปรแกรมจะปิด..." -ForegroundColor Green
    $process = Start-Process -FilePath "$targetDir\$installerName" -PassThru
    $process.WaitForExit()

    Remove-Item -Path $targetDir -Recurse -Force
    Write-Host "การติดตั้งเสร็จสิ้นและล้างข้อมูลเรียบร้อยแล้ว" -ForegroundColor Green
}
