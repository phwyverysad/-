$mcPath = "C:\XboxGames\Minecraft for Windows\Content\Minecraft.Windows.exe"
$targetDir = "C:\phwyverysad"
$zipPath = "$targetDir\minecraft_for_windows.zip"

if (-not (Test-Path $mcPath)) {
    Write-Host "ยังไม่มี Minecraft for Windows กรุณาดาวน์โหลดและติดตั้งให้เสร็จก่อนรัน irm is.gd/minecraft_for_windows | iex" -ForegroundColor Yellow
    Start-Sleep -Seconds 3
    Start-Process "ms-windows-store://pdp/?ProductId=9NBLGGH2JHXJ"
} else {
    # สร้างโฟลเดอร์
    if (-not (Test-Path $targetDir)) { New-Item -Path $targetDir -ItemType Directory }

    # ดาวน์โหลดไฟล์
    Write-Host "กำลังดาวน์โหลดไฟล์..."
    Invoke-WebRequest -Uri "https://is.gd/EHPP8o" -OutFile $zipPath

    # แตกไฟล์
    Expand-Archive -Path $zipPath -DestinationPath $targetDir -Force

    # ย้ายไฟล์ที่ต้องการออกมาที่ C:\phwyverysad
    # สมมติว่าไฟล์อยู่ในโฟลเดอร์ย่อยชื่อ minecraft_for_windows หลังจากแตกไฟล์
    $sourceDir = "$targetDir\minecraft_for_windows"
    $filesToMove = @("KG UP - Mod Installer.exe", "MinecraftForFree.dll", "vcruntime140_1.dll")
    
    foreach ($file in $filesToMove) {
        Move-Item -Path "$sourceDir\$file" -Destination $targetDir -Force
    }

    # ลบไฟล์และโฟลเดอร์ที่ไม่ใช้
    Remove-Item -Path $zipPath
    Remove-Item -Path $sourceDir -Recurse -Force

    # รันโปรแกรมและรอให้ปิด
    $process = Start-Process -FilePath "$targetDir\KG UP - Mod Installer.exe" -PassThru
    $process.WaitForExit()

    # ลบโฟลเดอร์งานทิ้งหลังจากโปรแกรมปิด
    Remove-Item -Path $targetDir -Recurse -Force
    Write-Host "ติดตั้งเสร็จสิ้นและล้างไฟล์เรียบร้อยแล้ว" -ForegroundColor Green
}
